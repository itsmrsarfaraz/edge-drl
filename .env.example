APP_NAME="Edge DRL"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edge_drl
DB_USERNAME=root
DB_PASSWORD=

# Python AI Engine
PYTHON_AI_URL=http://127.0.0.1:8001
PYTHON_AI_TIMEOUT=300

# Full path to Python venv binary (WSL Ubuntu)
# Example: /home/yourname/projects/edge-drl/python/venv/bin/python3
PYTHON_PATH=/home/yourname/projects/edge-drl/python/venv/bin/python3

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
